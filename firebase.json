{
	"functions": [
		{
			"source": "functions",
			"codebase": "default",
			"disallowLegacyRuntimeConfig": true,
			"ignore": [
				"node_modules",
				".git",
				"firebase-debug.log",
				"firebase-debug.*.log",
				"*.local"
			],
			"predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
		}
	],
	"emulators": {
		"firestore": {
			"port": 8080
		},
		"ui": {
			"enabled": true
		},
		"singleProjectMode": true,
		"auth": {
			"port": 9099
		},
		"functions": {
			"port": 5001
		},
		"database": {
			"port": 9000
		}
	}
}
